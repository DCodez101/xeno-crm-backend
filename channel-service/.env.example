PORT=4000

# Where the CRM backend is running — update this after CRM is deployed
CRM_RECEIPT_URL=http://localhost:5000/api/receipts

# Delivery simulation timings (ms)
DELIVERY_DELAY_MIN_MS=1000
DELIVERY_DELAY_MAX_MS=8000

# Base probabilities (0 to 1)
PROB_DELIVERED=0.80
PROB_FAILED=0.10
PROB_BOUNCED=0.10
PROB_OPENED=0.45
PROB_CLICKED=0.20

# Retry config for receipt callbacks
RECEIPT_MAX_RETRIES=3
RECEIPT_RETRY_DELAY_MS=2000
